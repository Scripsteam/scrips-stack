#!/bin/bash
# scrips-stack setup
set -e
shopt -s nullglob

SKILLS_DIR="$HOME/.claude/skills"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "Setting up scrips-stack from $SCRIPT_DIR..."
mkdir -p "$SKILLS_DIR"

# Does this platform actually make symlinks? Git Bash on Windows (without
# Developer Mode) silently turns `ln -s DIR` into a full directory COPY. That
# copy then looks like a user-placed non-symlink dir, so the skill loop below
# used to SKIP it on every re-run — freezing skill CONTENT at first-install
# version (a pull + ./setup refreshed hooks/telemetry but never the skills).
# Probe once, then branch: link where we can, refresh-copy where we can't.
SYMLINKS_OK=0
_probe="$SKILLS_DIR/.symlink-probe.$$"
ln -s "$SCRIPT_DIR" "$_probe" 2>/dev/null
[ -L "$_probe" ] && SYMLINKS_OK=1
rm -rf "$_probe"
[ "$SYMLINKS_OK" -eq 1 ] || echo "Note: symlinks unavailable here (Windows copy-fallback) — skills will be refresh-copied."

# Keep the umbrella so `~/.claude/skills/scrips/CLAUDE.md` resolves (referenced
# by the routing snippet in the README).
backup_path=""
if [ "$SCRIPT_DIR" != "$SKILLS_DIR/scrips" ]; then
  if [ "$SYMLINKS_OK" -eq 1 ]; then
    # Real symlink: back up a genuine user dir once, then link.
    if [ -d "$SKILLS_DIR/scrips" ] && [ ! -L "$SKILLS_DIR/scrips" ]; then
      backup_path="$SKILLS_DIR/scrips.bak.$(date +%s)"
      echo "Existing scrips dir at $SKILLS_DIR/scrips — backing up to $backup_path"
      mv "$SKILLS_DIR/scrips" "$backup_path"
    fi
    ln -sfn "$SCRIPT_DIR" "$SKILLS_DIR/scrips"
  else
    # Copy-fallback: refresh in place. The old code re-copied via `ln -sfn` AND
    # mv'd the prior copy to scrips.bak.<ts> on EVERY run — churning a new backup
    # dir each time. Replace cleanly instead (no per-run backup spam).
    rm -rf "$SKILLS_DIR/scrips"
    cp -r "$SCRIPT_DIR" "$SKILLS_DIR/scrips"
  fi
fi

# Register each skill flat — Claude Code's loader reads ~/.claude/skills/<name>/SKILL.md,
# not ~/.claude/skills/scrips/<name>/SKILL.md. Without these symlinks the slash commands
# never appear, even though the umbrella link above succeeds.
linked=0
replaced=0
skipped=0
linked_names=()
# Top-level command skills + the methodology/ collection (one level deeper).
# Both register flat as ~/.claude/skills/<name> so every one is a slash command.
for skill_md in "$SCRIPT_DIR"/*/SKILL.md "$SCRIPT_DIR"/methodology/*/SKILL.md; do
  [ -e "$skill_md" ] || continue
  name=$(basename "$(dirname "$skill_md")")
  # skip the methodology/ umbrella dir itself if it ever gets a top-level SKILL.md
  [ "$name" = "methodology" ] && continue
  target="$SKILLS_DIR/$name"
  desired="$(dirname "$skill_md")"

  if [ "$SYMLINKS_OK" -eq 1 ]; then
    # Symlink platform: don't clobber a genuine user-placed non-symlink dir.
    if [ -e "$target" ] && [ ! -L "$target" ]; then
      echo "  skip $name — non-symlink already exists at $target"
      skipped=$((skipped + 1))
      continue
    fi
    # If a symlink already exists pointing at another collection (e.g. gstack),
    # surface it as "replace" instead of silently retargeting.
    if [ -L "$target" ] && [ "$(readlink "$target")" != "$desired" ]; then
      echo "  replace $name — was → $(readlink "$target"), now → $desired"
      replaced=$((replaced + 1))
    fi
    ln -sfn "$desired" "$target"
  else
    # Copy-fallback (Windows): a prior install is a real dir copy that the old
    # code skipped, freezing it at first-install version. Refresh every run so
    # skill CONTENT tracks the repo after a pull. These names are kit-owned, so
    # an unconditional refresh is safe (no user-dir collision in practice).
    rm -rf "$target"
    cp -r "$desired" "$target"
  fi
  linked=$((linked + 1))
  linked_names+=("$name")
done

mkdir -p "$HOME/.scrips-stack"
printf '{"installed":"%s","source":"%s"}\n' \
  "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$SCRIPT_DIR" \
  > "$HOME/.scrips-stack/config.json"

# Install the engineering harness (DS-color gate, destructive-bash gate, FHIR
# advisor) so every dev runs the same guardrails. Backs up settings.json and
# appends only hooks not already present. Skip with SKIP_HARNESS=1.
if [ -z "$SKIP_HARNESS" ] && [ -f "$SCRIPT_DIR/harness/install-harness.sh" ]; then
  echo ""
  echo "Installing engineering harness (hooks + FHIR advisor)..."
  bash "$SCRIPT_DIR/harness/install-harness.sh" || echo "  (harness install skipped/failed — non-fatal)"
fi

echo ""
if [ "$SYMLINKS_OK" -eq 1 ]; then
  echo "scrips-stack installed: $linked linked ($replaced replaced from another collection), $skipped skipped."
else
  echo "scrips-stack installed: $linked skills refresh-copied (Windows copy-fallback — content now matches the repo)."
fi
[ -n "$backup_path" ] && echo "Backup of previous scrips dir: $backup_path (delete when satisfied)"

# Verify by checking what the loader actually reads — the file at
# ~/.claude/skills/<name>/SKILL.md. The previous `ls -la | grep '->'` form
# false-negatived on Windows Git Bash, where ln -s falls back to junctions
# or copies that don't render as `->` in `ls`.
echo ""
echo "Verify (loader truth — works on macOS, Linux, and Windows Git Bash):"
fail=0
for name in "${linked_names[@]}"; do
  if [ -f "$SKILLS_DIR/$name/SKILL.md" ]; then
    echo "  ✓ $name"
  else
    echo "  ✗ $name — SKILL.md not reachable at $SKILLS_DIR/$name/SKILL.md"
    fail=$((fail + 1))
  fi
done

echo ""
if [ "$fail" -eq 0 ]; then
  echo "All skills registered. In Claude Code: /ship /review /investigate /sprint /design-sync /qa /brief /retro /cso /checkpoint /admin-sprint-runner /onboard /synth /lesson /decompose-strategy"
  echo "Shared memory: read LESSONS.md (the team's accumulated lessons). Capture new ones with /lesson."
else
  echo "WARNING: $fail skill(s) not reachable. See above."
  exit 1
fi
